{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omne42.dev/schema/policy-meta.v1.json",
  "title": "PolicyMetaV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "risk_profile": {
      "type": "string",
      "enum": ["safe", "standard", "proactive", "danger"]
    },
    "write_scope": {
      "type": "string",
      "enum": ["read_only", "workspace_write", "full_access"]
    },
    "execution_isolation": {
      "type": "string",
      "enum": ["none", "best_effort", "strict"]
    },
    "decision": {
      "type": "string",
      "enum": ["allow", "prompt", "prompt_strict", "deny"]
    }
  }
}
